# Copy this file to .env and fill values for your environment
PORT=5000
MONGO_URI=mongodb://localhost:27017/aquaviora

# Optional: Google Sheets credentials path (place credentials.json at project root or change path)
GOOGLE_CREDENTIALS_PATH=credentials.json

# Optional SMTP settings for sending real emails
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM="AQUAVIORA Support <support@aquaviora.com>"
